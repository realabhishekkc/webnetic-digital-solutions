# ─────────────────────────────────────────────────────────────────
# Webnetic Digital Solutions — environment variables
# Copy this file to .env.local, fill in the values, and never
# commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# SMTP — Hostinger outgoing mail
# Used server-side only by app/api/contact/route.ts
# NEVER prefix these with NEXT_PUBLIC_
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@webnetic.com.au
SMTP_PASS=your-email-password-here

# Recipient for contact-form submissions (usually same as SMTP_USER)
CONTACT_EMAIL=info@webnetic.com.au

# Optional — set to "false" to stop sending the auto-confirmation email to the
# visitor (the enquiry notification to CONTACT_EMAIL is always sent). Defaults to on.
SEND_CONFIRMATION=true

# Tip: if your password contains special characters like @ ! # $, wrap the whole
# value in single quotes inside .env.local so it is read intact, e.g.
#   SMTP_PASS='my@pa!ss#word'
# In a hosting dashboard (Vercel/Hostinger), paste the password raw with NO quotes.
