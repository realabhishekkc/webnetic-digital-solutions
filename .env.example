# ─────────────────────────────────────────────────────────────────
# Webnetic Digital Solutions — environment variables
# Copy this file to .env.local, fill in the values, and never
# commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# SMTP — Hostinger outgoing mail
# Used server-side only by app/api/contact/route.ts
# NEVER prefix these with NEXT_PUBLIC_
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@webnetic.com.au
SMTP_PASS=your-email-password-here

# Recipient for contact-form submissions (usually same as SMTP_USER)
CONTACT_EMAIL=info@webnetic.com.au
