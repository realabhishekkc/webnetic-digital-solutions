# Resend API key — used by the /api/contact route handler to send contact-form emails.
# 1. Sign up at https://resend.com (free tier: 3,000 emails/month)
# 2. Add and verify your domain (webnetic.com.au) under Domains
# 3. Create an API key under API Keys
# 4. Copy this file to .env.local and paste your key below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
